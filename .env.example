# ─── Frontend (public, exposed to browser) ───────────────────────────────────
# Optional: override the API base URL (default: /api, served by Next.js itself)
# Only set this if you run the backend on a separate domain.
# NEXT_PUBLIC_APP_API_URL=https://your-backend-domain.com/api

# ─── Backend (server-only, never exposed to browser) ─────────────────────────
MONGODB_URI=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# JWT
JWT_SECRET=
